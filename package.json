{
  "name": "parallel-reader-chrome",
  "version": "0.0.2",
  "private": true,
  "description": "Anchor-based summary cards for any web page",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "check": "npm run lint && npm run check:no-cjk && npm run check:version && npm test && npm run typecheck && npm run build && npm audit --audit-level=high",
    "check:no-cjk": "node scripts/check-no-cjk.mjs",
    "check:version": "node scripts/check-version-consistency.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "e2e": "bash .e2e/gate.sh",
    "e2e:linux": "bash scripts/e2e-linux.sh",
    "lint": "biome lint src scripts tests esbuild.config.mjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "anchor:smoke": "node scripts/anchor-smoke.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/chrome": "^0.0.270",
    "esbuild": "^0.28.0",
    "playwright-core": "^1.59.1",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "zod": "^3.23.8"
  }
}
